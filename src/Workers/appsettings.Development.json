{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=NotifyService_Dev;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "RequestedHeartbeat": 60,
    "NetworkRecoveryInterval": 10,
    "AutomaticRecoveryEnabled": true
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "http://alloy:4317"
    }
  },
  "Workers": {
    "PrefetchCount": 1,
    "Retry": {
      "MaxAttempts": 5,
      "BaseDelayMs": 5000,
      "MaxDelayMs": 300000
    }
  },
  "RetryPolicy": {
    "WhatsApp": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    },
    "Email": {
      "MaxRetries": 3,
      "BaseDelaySeconds": 2,
      "MaxDelaySeconds": 30
    },
    "Telegram": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    },
    "MAX": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    }
  },
  "RateLimits": {
    "DefaultMaxRps": 0,
    "RedisRequestTimeoutMs": 100,
    "CapacityMultiplier": 1.5,
    "Providers": {
      "whatsapp": {
        "greenapi": {
          "MaxRequestsPerSecond": 10,
          "MaxRequestsPerSecondPerCredential": 5
        }
      },
      "telegram": {
        "telegramapi": {
          "MaxRequestsPerSecond": 30,
          "MaxRequestsPerSecondPerCredential": 15
        }
      },
      "email": {
        "smtp": {
          "MaxRequestsPerSecond": 20,
          "MaxRequestsPerSecondPerCredential": 10
        },
        "dashamailapi": {
          "MaxRequestsPerSecond": 20,
          "MaxRequestsPerSecondPerCredential": 10
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://alloy:4317",
          "protocol": "Grpc"
        }
      }
    ]
  }
}
