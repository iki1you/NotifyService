{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=NotifyService_Dev;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "RequestedHeartbeat": 60,
    "NetworkRecoveryInterval": 10,
    "AutomaticRecoveryEnabled": true
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "http://alloy:4317"
    }
  },
  "Workers": {
    "PrefetchCount": 1,
    "Retry": {
      "MaxAttempts": 5,
      "BaseDelayMs": 5000,
      "MaxDelayMs": 300000
    }
  },
  "RetryPolicy": {
    "WhatsApp": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    },
    "Email": {
      "MaxRetries": 3,
      "BaseDelaySeconds": 2,
      "MaxDelaySeconds": 30
    },
    "Telegram": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    },
    "MAX": {
      "MaxRetries": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 60
    }
  },
  "RateLimits": {
    "DefaultMaxRps": 5,
    "RedisRequestTimeoutMs": 100,
    "CapacityMultiplier": 1.5,
    "Providers": {
      "whatsapp:greenapi": {
        "MaxRequestsPerSecond": 10
      },
      "telegram:telegramapi": {
        "MaxRequestsPerSecond": 30
      },
      "email:smtp": {
        "MaxRequestsPerSecond": 20
      },
      "email:dashamailapi": {
        "MaxRequestsPerSecond": 20
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
