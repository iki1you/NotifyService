@page "/message-requests"

@using Data.Entities
@using AdminPanel.Services
@inject IDataService<MessageRequest> MessageRequestService
@inject NavigationManager Navigation
@inject ModalService ModalService
@rendermode InteractiveServer

<PageTitle>Message Requests</PageTitle>

<PageHeader Title="Message Requests">
    <PageHeaderExtra>
        <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="CreateNew">
            Create New
        </Button>
    </PageHeaderExtra>
</PageHeader>

@if (messageRequests == null)
{
    <Spin Size="@SpinSize.Large" Tip="Loading...">
        <div style="height: 200px;"></div>
    </Spin>
}
else if (!messageRequests.Any())
{
    <Alert Type="@AlertType.Info" Message="No message requests found." ShowIcon="true" />
}
else
{
    <Table TItem="MessageRequest" 
           DataSource="@messageRequests" 
           Loading="@loading"
           Bordered="true"
           Size="@TableSize.Small">
        <ColumnDefinitions>
            <PropertyColumn Property="c => c.Id" Sortable Width="80px" />
            <PropertyColumn Property="c => c.RequestId" Sortable Width="250px" />
            <PropertyColumn Property="c => c.TraceId" Sortable Width="250px" />
            <PropertyColumn Property="c => c.ProjectId" Sortable Width="100px" />
            <PropertyColumn Property="c => c.Status" Sortable Width="120px">
                <Tag Color="@GetStatusColor(context.Status)">@context.Status</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.TotalRecipients" Sortable Width="150px" />
            <PropertyColumn Property="c => c.CreatedAt" Format="g" Sortable Width="180px" />
            <PropertyColumn Property="c => c.UpdatedAt" Sortable Width="180px">
                @(context.UpdatedAt?.ToString("g") ?? "-")
            </PropertyColumn>
            <ActionColumn Title="Actions" Width="280px">
                <Space>
                    <SpaceItem>
                        <Button Type="@ButtonType.Primary" 
                                Icon="@IconType.Outline.Eye" 
                                Size="@ButtonSize.Small"
                                OnClick="() => View(context.Id)">
                            View
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Type="@ButtonType.Default" 
                                Icon="@IconType.Outline.Edit" 
                                Size="@ButtonSize.Small"
                                OnClick="() => Edit(context.Id)">
                            Edit
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="Are you sure you want to delete this message request?"
                                    OnConfirm="() => Delete(context.Id)"
                                    OkText="Yes"
                                    CancelText="No">
                            <Button Danger 
                                    Icon="@IconType.Outline.Delete" 
                                    Size="@ButtonSize.Small">
                                Delete
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ColumnDefinitions>
    </Table>
}

@code {
    private List<MessageRequest>? messageRequests;
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        messageRequests = await MessageRequestService.GetAllAsync();
        loading = false;
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/message-requests/create");
    }

    private void View(long id)
    {
        Navigation.NavigateTo($"/message-requests/view/{id}");
    }

    private void Edit(long id)
    {
        Navigation.NavigateTo($"/message-requests/edit/{id}");
    }

    private async Task Delete(long id)
    {
        await MessageRequestService.DeleteAsync(id);
        await LoadData();
    }

    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "orange",
            "processing" => "blue",
            "completed" => "green",
            "failed" => "red",
            "cancelled" => "gray",
            _ => "default"
        };
    }
}
