@page "/message-tasks/edit/{id:long}"

@using Data.Entities
@using AdminPanel.Components.DTO
@using AdminPanel.Services
@using Abstractions.Models.Enums
@using Microsoft.AspNetCore.Components.Forms
@using AdminPanel.Components.Pages.MessageTasks
@inject IDataService<MessageTask> MessageTaskService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Message Task</PageTitle>

<h1>Edit Message Task</h1>

@if (messageTask == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <MessageTaskForm Model="@messageTask" 
                     Mode="FormMode.Edit" 
                     OnValidSubmit="@HandleValidSubmit" 
                     OnCancel="@Cancel" />
}

@code {
    [Parameter]
    public long Id { get; set; }

    private MessageTask? messageTask;

    protected override async Task OnInitializedAsync()
    {
        messageTask = await MessageTaskService.GetByIdAsync(Id);
    }

    private async Task HandleValidSubmit()
    {
        if (messageTask != null)
        {
            await MessageTaskService.UpdateAsync(messageTask);
            Navigation.NavigateTo("/message-tasks");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/message-tasks");
    }
}
