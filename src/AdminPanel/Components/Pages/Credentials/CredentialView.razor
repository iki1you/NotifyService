@page "/credentials/view/{id:long}"

@using Data.Entities
@using AdminPanel.Services
@using System.Text.Json
@inject IDataService<Credential> CredentialService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>View Credential</PageTitle>

<PageHeader Title="Credential Details" OnBack="Back">
    <PageHeaderExtra>
        <Space>
            <SpaceItem>
                <Button Type="@ButtonType.Primary" 
                        Icon="@IconType.Outline.Edit" 
                        OnClick="Edit">
                    Edit
                </Button>
            </SpaceItem>
        </Space>
    </PageHeaderExtra>
</PageHeader>

@if (credential == null)
{
    <Spin Size="@SpinSize.Large" Tip="Loading...">
        <div style="height: 200px;"></div>
    </Spin>
}
else
{
    <Card>
        <Descriptions Bordered Column="1" Size="@DescriptionsSize.Middle">
            <DescriptionsItem Title="ID">
                @credential.Id
            </DescriptionsItem>

            <DescriptionsItem Title="Project ID">
                @credential.ProjectId
            </DescriptionsItem>

            <DescriptionsItem Title="Channel">
                <Tag Color="@("blue")">@credential.Channel</Tag>
            </DescriptionsItem>

            <DescriptionsItem Title="Adapter Type">
                <Tag Color="@("purple")">@credential.AdapterType</Tag>
            </DescriptionsItem>

            <DescriptionsItem Title="Configuration">
                <Paragraph>
                    <pre style="background: #f5f5f5; padding: 12px; border-radius: 4px; margin: 0;">@FormatJson(credential.Config)</pre>
                </Paragraph>
            </DescriptionsItem>

            <DescriptionsItem Title="Is Active">
                @if (credential.IsActive)
                {
                    <Tag Color="@("green")">Active</Tag>
                }
                else
                {
                    <Tag Color="@("default")">Inactive</Tag>
                }
            </DescriptionsItem>

            <DescriptionsItem Title="Created At">
                @credential.CreatedAt.ToString("F")
            </DescriptionsItem>

            <DescriptionsItem Title="Updated At">
                @(credential.UpdatedAt?.ToString("F") ?? "-")
            </DescriptionsItem>
        </Descriptions>

        <div style="margin-top: 24px;">
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" 
                            Icon="@IconType.Outline.Edit" 
                            OnClick="Edit">
                        Edit
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Icon="@IconType.Outline.ArrowLeft" 
                            OnClick="Back">
                        Back to List
                    </Button>
                </SpaceItem>
            </Space>
        </div>
    </Card>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private Credential? credential;

    protected override async Task OnInitializedAsync()
    {
        credential = await CredentialService.GetByIdAsync(Id);
    }

    private void Edit()
    {
        Navigation.NavigateTo($"/credentials/edit/{Id}");
    }

    private void Back()
    {
        Navigation.NavigateTo("/credentials");
    }

    private string FormatJson(JsonDocument doc)
    {
        using var stream = new MemoryStream();
        using var writer = new Utf8JsonWriter(stream, new JsonWriterOptions { Indented = true });
        doc.WriteTo(writer);
        writer.Flush();
        return System.Text.Encoding.UTF8.GetString(stream.ToArray());
    }
}
