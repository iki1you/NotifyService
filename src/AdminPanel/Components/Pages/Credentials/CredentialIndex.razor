@page "/credentials"

@using Data.Entities
@using AdminPanel.Services
@inject IDataService<Credential> CredentialService
@inject NavigationManager Navigation
@inject ModalService ModalService
@rendermode InteractiveServer

<PageTitle>Credentials</PageTitle>

<PageHeader Title="Credentials">
    <PageHeaderExtra>
        <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="CreateNew">
            Create New
        </Button>
    </PageHeaderExtra>
</PageHeader>

@if (credentials == null)
{
    <Spin Size="@SpinSize.Large" Tip="Loading...">
        <div style="height: 200px;"></div>
    </Spin>
}
else if (!credentials.Any())
{
    <Alert Type="@AlertType.Info" Message="No credentials found." ShowIcon="true" />
}
else
{
    <Table TItem="Credential" 
           DataSource="@credentials" 
           Loading="@loading"
           Bordered="true"
           Size="@TableSize.Small">
        <ColumnDefinitions>
            <PropertyColumn Property="c => c.Id" Sortable Width="80px" />
            <PropertyColumn Property="c => c.ProjectId" Sortable Width="100px" />
            <PropertyColumn Property="c => c.Channel" Sortable Width="120px">
                <Tag Color="@("blue")">@context.Channel</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.AdapterType" Sortable Width="150px">
                <Tag Color="@("purple")">@context.AdapterType</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.IsActive" Sortable Width="100px">
                @if (context.IsActive)
                {
                    <Tag Color="@("green")">Active</Tag>
                }
                else
                {
                    <Tag Color="@("default")">Inactive</Tag>
                }
            </PropertyColumn>
            <PropertyColumn Property="c => c.CreatedAt" Format="g" Sortable Width="180px" />
            <ActionColumn Title="Actions" Width="280px">
                <Space>
                    <SpaceItem>
                        <Button Type="@ButtonType.Primary" 
                                Icon="@IconType.Outline.Eye" 
                                Size="@ButtonSize.Small"
                                OnClick="() => View(context.Id)">
                            View
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Type="@ButtonType.Default" 
                                Icon="@IconType.Outline.Edit" 
                                Size="@ButtonSize.Small"
                                OnClick="() => Edit(context.Id)">
                            Edit
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="Are you sure you want to delete this credential?"
                                    OnConfirm="() => Delete(context.Id)"
                                    OkText="Yes"
                                    CancelText="No">
                            <Button Danger 
                                    Icon="@IconType.Outline.Delete" 
                                    Size="@ButtonSize.Small">
                                Delete
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ColumnDefinitions>
    </Table>
}

@code {
    private List<Credential>? credentials;
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        credentials = await CredentialService.GetAllAsync();
        loading = false;
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/credentials/create");
    }

    private void View(long id)
    {
        Navigation.NavigateTo($"/credentials/view/{id}");
    }

    private void Edit(long id)
    {
        Navigation.NavigateTo($"/credentials/edit/{id}");
    }

    private async Task Delete(long id)
    {
        await CredentialService.DeleteAsync(id);
        await LoadData();
    }
}
