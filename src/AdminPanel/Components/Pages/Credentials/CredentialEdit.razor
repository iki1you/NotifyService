@page "/credentials/edit/{id:long}"

@using Data.Entities
@using AdminPanel.Components.DTO
@using AdminPanel.Services
@using Abstractions.Models.Enums
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using AdminPanel.Components.Pages.Credentials
@inject IDataService<Credential> CredentialService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Credential</PageTitle>

<h1>Edit Credential</h1>

@if (credential == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <CredentialForm Model="@credential" 
                    Mode="FormMode.Edit" 
                    OnValidSubmit="@HandleValidSubmit" 
                    OnCancel="@Cancel" />
}

@code {
    [Parameter]
    public long Id { get; set; }

    private Credential? credential;

    protected override async Task OnInitializedAsync()
    {
        credential = await CredentialService.GetByIdAsync(Id);
    }

    private async Task HandleValidSubmit()
    {
        if (credential != null)
        {
            await CredentialService.UpdateAsync(credential);
            Navigation.NavigateTo("/credentials");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/credentials");
    }
}
