{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=NotifyService_Dev;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "RequestedHeartbeat": 60,
    "NetworkRecoveryInterval": 10,
    "AutomaticRecoveryEnabled": true
  },
  "Jwt": {
    "Issuer": "NotifyService",
    "Audience": "NotifyServiceClients",
    "SigningKey": "NotifyService_Development_Signing_Key_At_Least_32_Chars"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "http://alloy:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://alloy:4317",
          "protocol": "Grpc"
        }
      }
    ]
  }
}
