{
  "id": null,
  "uid": "notifyservice-observability",
  "title": "NotifyService Observability",
  "tags": ["notifyservice", "loki", "requestid"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "development,staging,production",
        "current": {
          "selected": true,
          "text": "development",
          "value": "development"
        },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "requestId",
        "type": "textbox",
        "label": "RequestId",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API requests (5m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=\"api\", env=~\"$env\"} |= \"API accepted send request\" [5m]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Statuses persisted (5m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=\"api\", env=~\"$env\"} |= \"persisted for request\" [5m]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Processed requests/sec",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({service=\"api\", env=~\"$env\"} |= \"persisted for request\" [1m]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p95 end-to-end latency, ms (API -> status persisted)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {service=\"api\", env=~\"$env\"} |= \"End-to-end latency from API receive:\" | regexp \".*End-to-end latency from API receive: (?P<elapsed_ms>[0-9]+(\\\\.[0-9]+)?) ms\" | unwrap elapsed_ms [5m])",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Processed requests/sec (RPS)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({service=\"api\", env=~\"$env\"} |= \"persisted for request\" [1m]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Request trace by RequestId",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"api|workers\", env=~\"$env\"} |= \"$requestId\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 queue lag, ms (queue.publish -> worker.receive)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {service=\"workers\", env=~\"$env\"} |= \"Queue lag for request\" | regexp \".*Queue lag for request .*: (?P<queue_lag_ms>[0-9]+(\\\\.[0-9]+)?) ms\" | unwrap queue_lag_ms [5m])",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Span-like errors (5m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=~\"api|workers\", env=~\"$env\"} |~ \"(?i)(error processing message|critical error|Failed to publish message|Failed to queue message|Error during API request)\" [5m]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "p95 db.insert_status, ms",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {service=\"api\", env=~\"$env\"} |= \"db.insert_status completed\" | regexp \".*db.insert_status completed .*: (?P<db_insert_ms>[0-9]+(\\\\.[0-9]+)?) ms\" | unwrap db_insert_ms [5m])",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    }
  ]
}

