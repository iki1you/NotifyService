@page "/message-tasks"
@using Data.Entities
@using AdminPanel.Services
@inject IDataService<MessageTask> MessageTaskService
@inject NavigationManager Navigation
@inject ModalService ModalService
@rendermode InteractiveServer

<PageTitle>Message Tasks</PageTitle>

<PageHeader Title="Message Tasks">
    <PageHeaderExtra>
        <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="CreateNew">
            Create New
        </Button>
    </PageHeaderExtra>
</PageHeader>

@if (messageTasks == null)
{
    <Spin Size="@SpinSize.Large" Tip="Loading...">
        <div style="height: 200px;"></div>
    </Spin>
}
else if (!messageTasks.Any())
{
    <Alert Type="@AlertType.Info" Message="No message tasks found." ShowIcon="true" />
}
else
{
    <Table TItem="MessageTask" 
           DataSource="@messageTasks" 
           Loading="@loading"
           Bordered="true"
           Size="@TableSize.Small">
        <ColumnDefinitions>
            <PropertyColumn Property="c => c.Id" Sortable Width="80px" />
            <PropertyColumn Property="c => c.RequestId" Sortable Width="250px" />
            <PropertyColumn Property="c => c.Channel" Sortable Width="120px">
                <Tag Color="@("blue")">@context.Channel</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.Recipient" Sortable Ellipsis />
            <PropertyColumn Property="c => c.Status" Sortable Width="120px">
                <Tag Color="@GetStatusColor(context.Status)">@context.Status</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.CreatedAt" Format="g" Sortable Width="180px" />
            <ActionColumn Title="Actions" Width="280px">
                <Space>
                    <SpaceItem>
                        <Button Type="@ButtonType.Primary" 
                                Icon="@IconType.Outline.Eye" 
                                Size="@ButtonSize.Small"
                                OnClick="() => View(context.Id)">
                            View
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Type="@ButtonType.Default" 
                                Icon="@IconType.Outline.Edit" 
                                Size="@ButtonSize.Small"
                                OnClick="() => Edit(context.Id)">
                            Edit
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="Are you sure you want to delete this message task?"
                                    OnConfirm="() => Delete(context.Id)"
                                    OkText="Yes"
                                    CancelText="No">
                            <Button Danger 
                                    Icon="@IconType.Outline.Delete" 
                                    Size="@ButtonSize.Small">
                                Delete
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ColumnDefinitions>
    </Table>
}

@code {
    private List<MessageTask>? messageTasks;
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        messageTasks = await MessageTaskService.GetAllAsync();
        loading = false;
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/message-tasks/create");
    }

    private void View(long id)
    {
        Navigation.NavigateTo($"/message-tasks/view/{id}");
    }

    private void Edit(long id)
    {
        Navigation.NavigateTo($"/message-tasks/edit/{id}");
    }

    private async Task Delete(long id)
    {
        await MessageTaskService.DeleteAsync(id);
        await LoadData();
    }

    private string GetStatusColor(Abstractions.Models.Enums.MessageTaskStatus status)
    {
        return status switch
        {
            Abstractions.Models.Enums.MessageTaskStatus.Pending => "orange",
            Abstractions.Models.Enums.MessageTaskStatus.Processing => "blue",
            Abstractions.Models.Enums.MessageTaskStatus.Sent => "green",
            Abstractions.Models.Enums.MessageTaskStatus.Failed => "red",
            Abstractions.Models.Enums.MessageTaskStatus.Rejected => "volcano",
            _ => "default"
        };
    }
}
