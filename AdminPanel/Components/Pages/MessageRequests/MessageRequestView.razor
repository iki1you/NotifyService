@page "/message-requests/view/{id:long}"

@using Data.Entities
@using AdminPanel.Services
@inject IDataService<MessageRequest> MessageRequestService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>View Message Request</PageTitle>

<PageHeader Title="Message Request Details" OnBack="Back">
    <PageHeaderExtra>
        <Space>
            <SpaceItem>
                <Button Type="@ButtonType.Primary" 
                        Icon="@IconType.Outline.Edit" 
                        OnClick="Edit">
                    Edit
                </Button>
            </SpaceItem>
        </Space>
    </PageHeaderExtra>
</PageHeader>

@if (messageRequest == null)
{
    <Spin Size="@SpinSize.Large" Tip="Loading...">
        <div style="height: 200px;"></div>
    </Spin>
}
else
{
    <Card>
        <Descriptions Bordered Column="1" Size="@DescriptionsSize.Middle">
            <DescriptionsItem Title="ID">
                @messageRequest.Id
            </DescriptionsItem>

            <DescriptionsItem Title="Request ID">
                <Text Code Copyable>@messageRequest.RequestId</Text>
            </DescriptionsItem>

            <DescriptionsItem Title="Project ID">
                @messageRequest.ProjectId
            </DescriptionsItem>

            <DescriptionsItem Title="Status">
                <Tag Color="@GetStatusColor(messageRequest.Status)">@messageRequest.Status</Tag>
            </DescriptionsItem>

            <DescriptionsItem Title="Total Recipients">
                @messageRequest.TotalRecipients
            </DescriptionsItem>

            <DescriptionsItem Title="Created At">
                @messageRequest.CreatedAt.ToString("F")
            </DescriptionsItem>

            <DescriptionsItem Title="Updated At">
                @(messageRequest.UpdatedAt?.ToString("F") ?? "-")
            </DescriptionsItem>
        </Descriptions>

        <div style="margin-top: 24px;">
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" 
                            Icon="@IconType.Outline.Edit" 
                            OnClick="Edit">
                        Edit
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Icon="@IconType.Outline.ArrowLeft" 
                            OnClick="Back">
                        Back to List
                    </Button>
                </SpaceItem>
            </Space>
        </div>
    </Card>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private MessageRequest? messageRequest;

    protected override async Task OnInitializedAsync()
    {
        messageRequest = await MessageRequestService.GetByIdAsync(Id);
    }

    private void Edit()
    {
        Navigation.NavigateTo($"/message-requests/edit/{Id}");
    }

    private void Back()
    {
        Navigation.NavigateTo("/message-requests");
    }

    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "orange",
            "processing" => "blue",
            "completed" => "green",
            "failed" => "red",
            "cancelled" => "gray",
            _ => "default"
        };
    }
}
