@using Data.Entities
@using Abstractions.Models.Enums
@using Microsoft.AspNetCore.Components.Forms
@using AdminPanel.Components.Pages.Credentials
@using AdminPanel.Components.DTO
@using System.Text.Json

<Form Model="@Model" OnFinish="@HandleFinish" LabelCol="new ColLayoutParam { Span = 6 }" WrapperCol="new ColLayoutParam { Span = 18 }">
    @if (Mode == FormMode.Edit)
    {
        <FormItem Label="ID">
            <AntDesign.InputNumber @bind-Value="@Model.Id" Disabled />
        </FormItem>
    }

    <FormItem Label="Project ID">
        <AntDesign.InputNumber @bind-Value="@Model.ProjectId" Disabled="@IsReadOnly" />
    </FormItem>

    <FormItem Label="Channel">
        <Input @bind-Value="@Model.Channel" Disabled="@IsReadOnly" Placeholder="Enter channel name" />
    </FormItem>

    <FormItem Label="Adapter Type">
        <Select @bind-Value="@Model.AdapterType" Disabled="@IsReadOnly" TItem="AdapterType" TItemValue="AdapterType">
            <SelectOptions>
                @foreach (AdapterType type in Enum.GetValues(typeof(AdapterType)))
                {
                    <SelectOption TItem="AdapterType" TItemValue="AdapterType" Value="@type" Label="@type.ToString()" />
                }
            </SelectOptions>
        </Select>
    </FormItem>

    <FormItem Label="Configuration">
        <TextArea @bind-Value="@ConfigJson" Rows="10" Disabled="@IsReadOnly" Placeholder="Enter JSON configuration" />
        @if (!string.IsNullOrEmpty(configError))
        {
            <div style="color: red; margin-top: 8px;">@configError</div>
        }
    </FormItem>

    <FormItem Label="Is Active">
        <Switch @bind-Value="@Model.IsActive" Disabled="@IsReadOnly" />
    </FormItem>

    <FormItem WrapperCol="new ColLayoutParam { Offset = 6, Span = 18 }">
        <Space>
            @if (Mode != FormMode.View)
            {
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" HtmlType="submit">@SubmitButtonText</Button>
                </SpaceItem>
            }
            <SpaceItem>
                <Button OnClick="@OnCancel">@CancelButtonText</Button>
            </SpaceItem>
        </Space>
    </FormItem>
</Form>

@code {
    [Parameter]
    public Credential Model { get; set; } = null!;

    [Parameter]
    public FormMode Mode { get; set; } = FormMode.Create;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private string configJson = "{}";
    private string configError = "";

    private bool IsReadOnly => Mode == FormMode.View;

    private string SubmitButtonText => Mode switch
    {
        FormMode.Create => "Create",
        FormMode.Edit => "Update",
        _ => "Submit"
    };

    private string CancelButtonText => Mode == FormMode.View ? "Back" : "Cancel";

    public string ConfigJson
    {
        get => configJson;
        set
        {
            configJson = value;
            configError = "";
        }
    }

    protected override void OnParametersSet()
    {
        if (Model?.Config != null)
        {
            configJson = Model.Config.RootElement.GetRawText();
        }
    }

    private async Task HandleFinish(EditContext editContext)
    {
        try
        {
            Model.Config = JsonDocument.Parse(configJson);
            configError = "";
            await OnValidSubmit.InvokeAsync();
        }
        catch (JsonException)
        {
            configError = "Invalid JSON format";
        }
    }
}
